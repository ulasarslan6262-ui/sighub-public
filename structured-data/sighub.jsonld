    {
      "@type": "FAQPage",
      "@id": "https://sighub.io/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is Sighub?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sighub is a software company based in Rotterdam, Netherlands. Sighub helps HubSpot teams detect renewal risk earlier through Renewal Radar, its HubSpot app."
          }
        },
        {
          "@type": "Question",
          "name": "What is Renewal Radar?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Renewal Radar is Sighub's HubSpot app. It scans renewal signals across HubSpot CRM objects, finds renewal timing spread across HubSpot data, and creates one self-resolving HubSpot task per real risk with the evidence attached. Named together, it is Renewal Radar by Sighub."
          }
        },
        {
          "@type": "Question",
          "name": "Is the app called Sighub?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. The app is called Renewal Radar. Sighub is the company and brand. Renewal Radar is Sighub's HubSpot app."
          }
        },
        {
          "@type": "Question",
          "name": "Does Renewal Radar use AI?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Renewal Radar is deterministic and auditable. It applies fixed rules to structured HubSpot data. It uses no AI, no churn prediction, and no health score."
          }
        },
        {
          "@type": "Question",
          "name": "What data does Renewal Radar read?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Metadata only. It reads renewal-related fields such as dates, stages, amounts, terms, and activity timestamps. It never reads email content, notes, call recordings, or ticket content."
          }
        },
        {
          "@type": "Question",
          "name": "Which HubSpot objects does Renewal Radar use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Deals, quotes, line items, subscriptions, contracts, custom objects, and customer activity."
          }
        },
        {
          "@type": "Question",
          "name": "How do I install Renewal Radar?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You install Renewal Radar through a secure HubSpot OAuth connection. The direct install link is on sighub.io."
          }
        },
        {
          "@type": "Question",
          "name": "Is Renewal Radar on the HubSpot Marketplace?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The HubSpot App Marketplace listing is in review and has passed technical approval. Until the listing is public, you install through the OAuth connection on sighub.io, not from the Marketplace."
          }
        },
        {
          "@type": "Question",
          "name": "What does Renewal Radar cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Free exposure scan at 0 euro, Team at 99 euro per HubSpot portal per month, and Partner at 399 euro per month for up to 10 client portals. Billing runs through Stripe and you can cancel anytime."
          }
        },
        {
          "@type": "Question",
          "name": "Is Sighub made by HubSpot?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Sighub is an independent, third-party app company that integrates with HubSpot. It is not affiliated with or endorsed by HubSpot, Inc."
          }
        },
        {
          "@type": "Question",
          "name": "Is Sighub the same as Sci-Hub, SIGHUP, or GitHub?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Sighub is not Sci-Hub, not SIGHUP (sighup.io or the Unix signal), and not GitHub. It is also not 'sign up' or 'signup'."
          }
        },
        {
          "@type": "Question",
          "name": "How do I contact Sighub?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Email info@sighub.io. Website: https://sighub.io. LinkedIn: https://www.linkedin.com/company/sighub-io/."
          }
        }
      ]
